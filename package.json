{
  "name": "react-skeletonix",
  "version": "1.0.2",
  "description": "The smartest and most performant React skeleton loader. Automatically generates high-fidelity skeleton screens and loading placeholders from existing components with zero configuration. Supports shimmer, pulse, wave, and blink animations for superior UX.",
  "main": "./dist/react-skeletonix.umd.js",
  "module": "./dist/react-skeletonix.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/react-skeletonix.es.js",
      "require": "./dist/react-skeletonix.umd.js"
    },
    "./dist/style.css": "./dist/style.css",
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "keywords": [
    "react",
    "skeleton",
    "loading",
    "placeholder",
    "ui",
    "dynamic",
    "shimmer",
    "pulse",
    "auto-generated",
    "zero-config",
    "content-loader",
    "typescript",
    "ux",
    "loading-states",
    "skeletonix",
    "skeleton-loader",
    "skeleton-ui",
    "react-skeleton-loader",
    "skeleton-screen",
    "react-loading-skeleton",
    "content-placeholder",
    "ghost-elements",
    "ux-design"
  ],
  "author": {
    "name": "Amit Kumar",
    "url": "https://www.linkedin.com/in/amitkumar9297/"
  },
  "maintainers": [
    {
      "name": "devpranali",
      "url": "https://github.com/devpranali"
    }
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devpranali/react-skeletonix.git"
  },
  "homepage": "https://doc.react-skeletonix.devpranali.com/",
  "bugs": {
    "url": "https://github.com/devpranali/react-skeletonix/issues"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.0.0",
    "vite": "^4.4.0",
    "vite-plugin-dts": "^3.0.0"
  }
}